<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <LinearLayout
        android:layout_width="360dp"
        android:layout_height="match_parent"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/panel_bg"
        android:orientation="vertical"
        android:paddingLeft="30dp"
        android:paddingRight="30dp"
        android:paddingTop="94dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="86dp"
                android:layout_height="wrap_content"
                android:text="@string/phone_label"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/phoneInput"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:inputType="phone"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="31dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="86dp"
                android:layout_height="wrap_content"
                android:text="@string/sms_label"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/contentInput"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:inputType="text"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="86dp"
                android:layout_height="wrap_content"
                android:text="@string/mock_phone_label"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/mockPhoneInput"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:inputType="phone"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="86dp"
                android:layout_height="wrap_content"
                android:text="@string/mock_sms_label"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/mockContentInput"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:inputType="text"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:singleLine="true"
                android:textColor="@color/ink"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="42dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/testButton"
                android:layout_width="84dp"
                android:layout_height="26dp"
                android:background="@drawable/button_dark"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/test"
                android:textAllCaps="false"
                android:textColor="@color/danger_red"
                android:textSize="12sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="76dp"
                android:layout_height="34dp"
                android:background="@drawable/button_blue"
                android:drawableLeft="@drawable/ic_save"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:text="@string/save"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/ringtoneButton"
                android:layout_width="76dp"
                android:layout_height="32dp"
                android:background="@drawable/button_outline"
                android:drawableLeft="@drawable/ic_music"
                android:drawablePadding="4dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingLeft="7dp"
                android:paddingRight="7dp"
                android:text="@string/choose_ringtone"
                android:textAllCaps="false"
                android:textColor="@color/muted"
                android:textSize="11sp" />
        </LinearLayout>

        <Button
            android:id="@+id/stopButton"
            android:layout_width="112dp"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:background="@drawable/button_dark"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="@string/stop_playback"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/permissionButton"
                android:layout_width="132dp"
                android:layout_height="30dp"
                android:background="@drawable/button_outline"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/request_sms_permission"
                android:textAllCaps="false"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/notificationPermissionButton"
                android:layout_width="132dp"
                android:layout_height="30dp"
                android:background="@drawable/button_outline"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/request_notification_permission"
                android:textAllCaps="false"
                android:textColor="@color/muted"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/ringtoneName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="86dp"
                android:layout_height="wrap_content"
                android:text="@string/volume"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/volumeSeek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100" />

            <TextView
                android:id="@+id/volumeValue"
                android:layout_width="42dp"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:textColor="@color/muted"
                android:textSize="12sp" />
        </LinearLayout>

        <Switch
            android:id="@+id/vibrateSwitch"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:text="@string/vibrate_when_playing"
            android:textColor="@color/ink"
            android:textSize="13sp" />

        <Switch
            android:id="@+id/hideFromRecentsSwitch"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="4dp"
            android:text="@string/hide_from_recents"
            android:textColor="@color/ink"
            android:textSize="13sp" />

        <Switch
            android:id="@+id/smsObserverSwitch"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="4dp"
            android:text="@string/sms_observer"
            android:textColor="@color/ink"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="@color/muted"
            android:textSize="12sp" />
    </LinearLayout>
</FrameLayout>
